generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas = ["laboratorios", "grupo1_academico", "pago_alumnos"]
}

enum RolUsuario {
  ADMINISTRADOR
  TECNICO
  CATEDRATICO
  ESTUDIANTE
}

enum CategoriaUsuario {
  ESTUDIANTE_UNIVERSITARIO
  PERSONAL_COLEGIO
  PERSONAL_IGLESIA
  EVENTO_EXTERNO
  CATEDRATICO
}

enum TipoLaboratorio {
  COMPUTACION
  PLC_CNC
  QUIMICA
  FISICA
}

enum EstadoLaboratorio {
  ACTIVO
  INACTIVO
  MANTENIMIENTO
}

enum EstadoReserva {
  PENDIENTE
  APROBADA
  RECHAZADA
  COMPLETADA
  CANCELADA
}

enum TipoCobro {
  CUOTA_SEMESTRAL
  PAGO_HORA
  PAGO_DIA
  PAGO_SEMESTRE
  RESERVACION_GRUPO
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  ANULADO
}

enum EstadoEquipo {
  OPERATIVO
  MANTENIMIENTO
  DANADO
  BAJA
}

enum TipoConexion {
  PRESENCIAL
  REMOTA
}

enum TipoSancion {
  AMONESTACION
  SUSPENSION_TEMPORAL
  EXPULSION
}

enum EstadoMantenimiento {
  PROGRAMADO
  EN_PROCESO
  COMPLETADO
}

enum EstadoReporteDano {
  REPORTADO
  EN_REVISION
  COBRADO
  CERRADO
}

model Usuario {
  id               String           @id @default(uuid())
  correo           String           @unique
  nombre           String
  apellido         String?
  rol              RolUsuario       @default(ESTUDIANTE)
  categoria        CategoriaUsuario @default(ESTUDIANTE_UNIVERSITARIO)
  carrera          String?
  activo           Boolean          @default(true)
  reglamentoAcep   Boolean          @default(false) @map("reglamento_acep")
  sancionado       Boolean          @default(false)
  eventoExternoRef String?          @map("evento_externo_ref")

  reservas               Reserva[]              @relation("ReservaSolicitante")
  reservasAprobadas      Reserva[]              @relation("ReservaAprobador")
  sesionesUso            SesionUso[]
  pagos                  Pago[]
  sanciones              Sancion[]
  aceptacionesReglamento ReglamentoAceptacion[]
  reportesDano           ReporteDano[]          @relation("ReportePor")
  danosResponsable       ReporteDano[]          @relation("DanoResponsable")
  infracciones           Infraccion[]
  mantenimientos         MantenimientoEquipo[]  @relation("MantenimientoTecnico")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("usuario")
}

model Reglamento {
  id           Int                    @id @default(autoincrement())
  version      String                 @unique
  titulo       String
  contenido    String                 @db.Text
  activo       Boolean                @default(true)
  vigenteDesde DateTime               @default(now()) @map("vigente_desde")
  aceptaciones ReglamentoAceptacion[]
  createdAt    DateTime               @default(now()) @map("created_at")

  @@map("reglamento")
}

model ReglamentoAceptacion {
  id           Int      @id @default(autoincrement())
  usuarioId    String   @map("usuario_id")
  reglamentoId Int      @map("reglamento_id")
  aceptadoEn   DateTime @default(now()) @map("aceptado_en")

  usuario    Usuario    @relation(fields: [usuarioId], references: [id])
  reglamento Reglamento @relation(fields: [reglamentoId], references: [id])

  @@unique([usuarioId, reglamentoId])
  @@map("reglamento_aceptacion")
}

model Sancion {
  id            Int         @id @default(autoincrement())
  usuarioId     String      @map("usuario_id")
  tipo          TipoSancion
  motivo        String
  aplicadaPorId String?     @map("aplicada_por_id")
  fechaInicio   DateTime    @default(now()) @map("fecha_inicio")
  fechaFin      DateTime?   @map("fecha_fin")
  levantada     Boolean     @default(false)
  notas         String?

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sancion")
}

model Laboratorio {
  id                 Int               @id @default(autoincrement())
  codigo             String            @unique @default("LAB-GEN")
  nombre             String
  descripcion        String?
  ubicacion          String?
  tipo               TipoLaboratorio   @default(COMPUTACION)
  capacidadTotal     Int               @default(30) @map("capacidad_total")
  permiteDivision    Boolean           @default(true) @map("permite_division")
  estado             EstadoLaboratorio @default(ACTIVO)
  faseImplementacion Int               @default(1) @map("fase_implementacion")
  disponiblePublico  Boolean           @default(true) @map("disponible_publico")

  configuraciones ConfiguracionDivision[]
  estaciones      Estacion[]
  equipos         Equipo[]
  reservas        Reserva[]
  pagos           Pago[]
  sesionesUso     SesionUso[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("laboratorio")
}

model ConfiguracionDivision {
  id              Int     @id @default(autoincrement())
  laboratorioId   Int     @map("laboratorio_id")
  etiqueta        String
  cupo            Int
  esGrupoCompleto Boolean @default(false) @map("es_grupo_completo")
  activo          Boolean @default(true)
  orden           Int     @default(0)

  laboratorio Laboratorio @relation(fields: [laboratorioId], references: [id], onDelete: Cascade)
  reservas    Reserva[]

  @@map("configuracion_division")
}

model Estacion {
  id            Int     @id @default(autoincrement())
  laboratorioId Int     @map("laboratorio_id")
  nombre        String
  tipo          String
  descripcion   String?
  orden         Int     @default(0)
  activo        Boolean @default(true)

  laboratorio Laboratorio @relation(fields: [laboratorioId], references: [id], onDelete: Cascade)

  @@map("estacion")
}

model Equipo {
  id               Int          @id @default(autoincrement())
  laboratorioId    Int          @map("laboratorio_id")
  codigoInventario String       @unique @map("codigo_inventario")
  nombre           String
  esServidor       Boolean      @default(false) @map("es_servidor")
  estado           EstadoEquipo @default(OPERATIVO)
  ubicacionFisica  String?      @map("ubicacion_fisica")

  laboratorio    Laboratorio           @relation(fields: [laboratorioId], references: [id], onDelete: Cascade)
  sesionesUso    SesionUso[]
  reportesDano   ReporteDano[]
  mantenimientos MantenimientoEquipo[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("equipo")
}

model MantenimientoEquipo {
  id          Int                 @id @default(autoincrement())
  equipoId    Int                 @map("equipo_id")
  tecnicoId   String?             @map("tecnico_id")
  tipo        String
  descripcion String
  costo       Decimal?            @db.Decimal(10, 2)
  estado      EstadoMantenimiento @default(PROGRAMADO)
  fecha       DateTime            @default(now())

  equipo    Equipo   @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  tecnico   Usuario? @relation("MantenimientoTecnico", fields: [tecnicoId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@map("mantenimiento_equipo")
}

model ReporteDano {
  id                   Int               @id @default(autoincrement())
  equipoId             Int               @map("equipo_id")
  reportadoPorId       String            @map("reportado_por_id")
  usuarioResponsableId String?           @map("usuario_responsable_id")
  descripcion          String
  requiereCobro        Boolean           @default(false) @map("requiere_cobro")
  montoCobro           Decimal?          @map("monto_cobro") @db.Decimal(10, 2)
  estado               EstadoReporteDano @default(REPORTADO)

  equipo             Equipo   @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  reportadoPor       Usuario  @relation("ReportePor", fields: [reportadoPorId], references: [id])
  usuarioResponsable Usuario? @relation("DanoResponsable", fields: [usuarioResponsableId], references: [id])
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("reporte_dano")
}

model Reserva {
  id                      String        @id @default(uuid())
  usuarioId               String        @map("usuario_id")
  laboratorioId           Int           @map("laboratorio_id")
  configuracionDivisionId Int?          @map("configuracion_division_id")
  fechaInicio             DateTime      @map("fecha_inicio")
  fechaFin                DateTime      @map("fecha_fin")
  cantidadPersonas        Int           @map("cantidad_personas")
  proposito               String
  estado                  EstadoReserva @default(PENDIENTE)
  aprobadaPorId           String?       @map("aprobada_por_id")
  notas                   String?
  motivoRechazo           String?       @map("motivo_rechazo")
  motivoCancelacion       String?       @map("motivo_cancelacion")

  usuario               Usuario                @relation("ReservaSolicitante", fields: [usuarioId], references: [id])
  laboratorio           Laboratorio            @relation(fields: [laboratorioId], references: [id])
  configuracionDivision ConfiguracionDivision? @relation(fields: [configuracionDivisionId], references: [id])
  aprobadaPor           Usuario?               @relation("ReservaAprobador", fields: [aprobadaPorId], references: [id])
  pagos                 Pago[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([laboratorioId, fechaInicio, fechaFin])
  @@map("reserva")
}

model Pago {
  id                String     @id @default(uuid())
  usuarioId         String     @map("usuario_id")
  laboratorioId     Int?       @map("laboratorio_id")
  reservaId         String?    @map("reserva_id")
  monto             Decimal    @db.Decimal(10, 2)
  tipoCobro         TipoCobro  @map("tipo_cobro")
  metodoPago        String     @map("metodo_pago")
  estado            EstadoPago @default(PENDIENTE)
  referenciaExterna String?    @map("referencia_externa")
  notas             String?

  usuario     Usuario      @relation(fields: [usuarioId], references: [id])
  laboratorio Laboratorio? @relation(fields: [laboratorioId], references: [id])
  reserva     Reserva?     @relation(fields: [reservaId], references: [id])
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("pago")
}

model SesionUso {
  id                String       @id @default(uuid())
  usuarioId         String       @map("usuario_id")
  laboratorioId     Int?         @map("laboratorio_id")
  equipoId          Int?         @map("equipo_id")
  tipoConexion      TipoConexion @default(PRESENCIAL) @map("tipo_conexion")
  inicio            DateTime     @default(now())
  fin               DateTime?
  registroActividad Json?        @map("registro_actividad")

  usuario      Usuario      @relation(fields: [usuarioId], references: [id])
  laboratorio  Laboratorio? @relation(fields: [laboratorioId], references: [id])
  equipo       Equipo?      @relation(fields: [equipoId], references: [id])
  infracciones Infraccion[]

  @@map("sesion_uso")
}

model Infraccion {
  id              Int      @id @default(autoincrement())
  usuarioId       String   @map("usuario_id")
  sesionUsoId     String?  @map("sesion_uso_id")
  descripcion     String
  sancionAplicada Boolean  @default(false) @map("sancion_aplicada")

  usuario   Usuario    @relation(fields: [usuarioId], references: [id])
  sesionUso SesionUso? @relation(fields: [sesionUsoId], references: [id])
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("infraccion")
}

// ─── Sistema Académico (Grupo 1) ─────────────────────────────────────────────

model Carrera {
  id                  Int                   @id @default(autoincrement())
  codigo              String                @unique
  nombre              String
  facultad            String?
  nivel               String                @default("LICENCIATURA")
  activo              Boolean               @default(true)
  createdAt           DateTime              @default(now())
  alumnos             Alumno[]
  planesEstudio       PlanEstudio[]
  solicitudes         SolicitudInscripcion[]
}

model Alumno {
  id           Int          @id @default(autoincrement())
  carnet       String       @unique
  nombre       String
  apellido     String
  email        String       @unique
  password     String?
  carreraId    Int?
  carrera      Carrera?     @relation(fields: [carreraId], references: [id])
  createdAt    DateTime     @default(now())
  asignaciones Asignacion[]
  asistencias  Asistencia[]
}

model CatedraticoAcademico {
  id        Int       @id @default(autoincrement())
  codigo    String    @unique
  nombre    String
  apellido  String
  email     String    @unique
  password  String?
  createdAt DateTime  @default(now())
  horarios  Horario[]
}

model Curso {
  id           Int          @id @default(autoincrement())
  codigo       String       @unique
  nombre       String
  creditos     Int
  createdAt    DateTime     @default(now())
  asignaciones Asignacion[]
  horarios     Horario[]
  planesCurso  CursoPlan[]
}

model Asignacion {
  id        Int      @id @default(autoincrement())
  alumno    Alumno   @relation(fields: [alumnoId], references: [id])
  alumnoId  Int
  curso     Curso    @relation(fields: [cursoId], references: [id])
  cursoId   Int
  ciclo     String
  createdAt DateTime @default(now())

  @@unique([alumnoId, cursoId, ciclo])
}

model Horario {
  id            Int                  @id @default(autoincrement())
  curso         Curso                @relation(fields: [cursoId], references: [id])
  cursoId       Int
  catedratico   CatedraticoAcademico @relation(fields: [catedraticoId], references: [id])
  catedraticoId Int
  dia           String
  horaInicio    String
  horaFin       String
  salon         String
  asistencias   Asistencia[]
}

model Asistencia {
  id        Int      @id @default(autoincrement())
  alumno    Alumno   @relation(fields: [alumnoId], references: [id])
  alumnoId  Int
  horario   Horario  @relation(fields: [horarioId], references: [id])
  horarioId Int
  fecha     DateTime
  presente  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([alumnoId, horarioId, fecha])
}

model SolicitudInscripcion {
  id        Int      @id @default(autoincrement())
  nombre    String
  apellido  String
  email     String
  telefono  String
  carreraId Int
  carrera   Carrera  @relation(fields: [carreraId], references: [id])
  estado    String   @default("PENDIENTE")
  motivo    String?
  createdAt DateTime @default(now())
}

model PlanEstudio {
  id            Int         @id @default(autoincrement())
  carreraId     Int
  carrera       Carrera     @relation(fields: [carreraId], references: [id])
  nombre        String
  version       String
  totalCreditos Int
  createdAt     DateTime    @default(now())
  cursos        CursoPlan[]
}

model CursoPlan {
  id            Int         @id @default(autoincrement())
  planEstudioId Int
  planEstudio   PlanEstudio @relation(fields: [planEstudioId], references: [id])
  cursoId       Int
  curso         Curso       @relation(fields: [cursoId], references: [id])
  semestre      Int
  obligatorio   Boolean     @default(true)

  @@unique([planEstudioId, cursoId])
}

// ─── Tablas Pago Alumnos ─────────────────────────────────────────────────────
model FormaPago {
  id_forma_pago Int    @id @default(autoincrement())
  nombre        String @map("Nombre")
  descripcion   String? @map("Descripcion")

  matriculas    Matricula[]
  mensualidades Mensualidad[]
  pagosVarios   PagosVarios[]

  @@map("forma_pago")
}

model Matricula {
  id_matricula  Int      @id @default(autoincrement())
  carnet        String
  ciclo         String   @map("Ciclo")
  anio          Int      @map("Anio")
  fechaPago     DateTime @map("Fecha_pago") @db.Date
  precio        Decimal  @db.Decimal(10, 2)
  idFormaPago   Int      @map("id_forma_pago")
  estado        String   @default("Pendiente") @map("Estado")

  formaPago     FormaPago @relation(fields: [idFormaPago], references: [id_forma_pago])

  @@unique([carnet, ciclo, anio])
  @@map("matricula")
}

model Mensualidad {
  id_mensualidad  Int      @id @default(autoincrement())
  carnet          String
  mes             String   @map("Mes")
  fechaPago       DateTime? @map("Fecha_Pago") @db.Date
  fechaLimite     DateTime @map("Fecha_limite") @db.Date
  precio          Decimal  @db.Decimal(10, 2)
  idFormaPago     Int      @map("id_forma_pago")
  estadoPago      String   @default("Pendiente") @map("Estado_pago")
  montoMora       Decimal  @default(0.00) @map("Monto_mora") @db.Decimal(10, 2)
  diasMora        Int      @default(0) @map("Dias_mora")

  formaPago       FormaPago @relation(fields: [idFormaPago], references: [id_forma_pago])
  solvenciasMensuales SolvenciaMensual[]

  @@map("mensualidad")
}

model PagosVarios {
  id_pagos_varios Int      @id @default(autoincrement())
  carnet          String
  motivoPago      String   @map("Motivo_pago")
  monto           Decimal  @db.Decimal(10, 2)
  fechaPago       DateTime @map("Fecha_pago") @db.Date
  idFormaPago     Int      @map("id_forma_pago")
  estado          String   @default("Registrado") @map("Estado")

  formaPago       FormaPago @relation(fields: [idFormaPago], references: [id_forma_pago])

  @@map("pagos_varios")
}

model Recibos {
  id_recibo         Int      @id @default(autoincrement())
  carnet            String
  idReferencia      Int      @map("id_referencia")
  tipoReferencia    String   @map("tipo_referencia")
  fechaEmision      DateTime @default(now()) @map("Fecha_emision") @db.Date
  montoTotal        Decimal  @db.Decimal(10, 2) @map("Monto_total")
  estadoValidacion  String   @default("Emitido") @map("Estado_validacion")

  comprobantes      ComprobantePago[]

  @@map("recibos")
}

model ComprobantePago {
  id_comprobante    Int      @id @default(autoincrement())
  idRecibo          Int      @map("id_recibo")
  archivoUrl        String?  @map("archivo_url")
  numTransferencia  String?  @map("num_transferencia")
  bancoOrigen       String?  @map("banco_origen")
  fechaAdjunto      DateTime @default(now()) @map("fecha_adjunto") @db.Date
  estado            String   @default("Pendiente")
  observacion       String?

  recibo            Recibos @relation(fields: [idRecibo], references: [id_recibo])

  @@map("comprobante_pago")
}

model SolvenciaMensual {
  id_solvencia_mensual Int    @id @default(autoincrement())
  idMensualidad        Int    @map("id_mensualidad")
  estado               String @default("No Solvente") @map("Estado")

  mensualidad          Mensualidad @relation(fields: [idMensualidad], references: [id_mensualidad])
  solvencias           Solvencia[]

  @@map("solvenciamensual")
}

model Solvencia {
  id_solvencia          Int      @id @default(autoincrement())
  carnet                String
  idSolvenciaMensual    Int      @map("id_solvencia_mensual")
  estado                String   @default("No Solvente") @map("Estado")
  fechaEmision          DateTime @default(now()) @map("Fecha_emision") @db.Date
  corte                 String   @map("Corte")

  solvenciaMensual      SolvenciaMensual @relation(fields: [idSolvenciaMensual], references: [id_solvencia_mensual])

  @@map("solvencia")
}

model DeudaExterna {
  id_deuda      Int      @id @default(autoincrement())
  carnet        String
  concepto      String   @map("Concepto")
  monto         Decimal  @db.Decimal(10, 2) @map("Monto")
  estado        String   @default("Pendiente") @map("Estado")
  fechaReporte  DateTime @default(now()) @map("Fecha_reporte") @db.Date
  grupoOrigen   String?  @map("Grupo_origen")

  @@map("deuda_externa")
}