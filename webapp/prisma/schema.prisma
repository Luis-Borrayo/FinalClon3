generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["grupo5_parqueo", "grupo1_academico", "grupo3_laboratorios", "grupo9_otras_actividades"]
}

enum Role {
  ADMIN
  SECURITY
  TEACHER
  STUDENT
  VISITOR

  @@schema("grupo5_parqueo")
}

enum Zone {
  A
  B
  C
  D

  @@schema("grupo5_parqueo")
}

enum SpaceType {
  STANDARD
  VIP
  HANDICAPPED
  ELECTRIC
  RESERVED
  TEACHER

  @@schema("grupo5_parqueo")
}

enum SpaceStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE

  @@schema("grupo5_parqueo")
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED

  @@schema("grupo5_parqueo")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED

  @@schema("grupo5_parqueo")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  QR_CODE
  MOBILE

  @@schema("grupo5_parqueo")
}

enum EntryMethod {
  QR
  PLATE
  NFC
  MANUAL
  VISITOR_QR

  @@schema("grupo5_parqueo")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  USED

  @@schema("grupo5_parqueo")
}

enum ReservationType {
  STANDARD
  PERSONAL
  EVENT
  SPECIAL_VISIT

  @@schema("grupo5_parqueo")
}

enum NotificationType {
  PARKING_FULL
  VISITOR_EXPIRING
  OVERSTAY
  INVALID_ACCESS
  PAYMENT_REQUIRED
  RESERVATION_EXPIRING
  BARRIER_ACTION
  SYSTEM_ALERT
  BLACKLIST
  INFO

  @@schema("grupo5_parqueo")
}

enum BarrierAction {
  OPEN
  CLOSE
  BLOCK
  ERROR

  @@schema("grupo5_parqueo")
}

enum TriggerSource {
  QR
  PLATE
  NFC
  MANUAL
  SYSTEM
  PAYMENT

  @@schema("grupo5_parqueo")
}

enum Orientation {
  HORIZONTAL
  DIAGONAL
  VERTICAL

  @@schema("grupo5_parqueo")
}

model Campus {
  id           String   @id @default(uuid())
  name         String
  address      String
  lat          Float
  lng          Float
  zoom         Int      @default(18)
  total_spaces Int      @default(500)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  spaces  ParkingSpace[]
  cameras Camera[]

  @@schema("grupo5_parqueo")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password_hash String
  role          Role      @default(STUDENT)
  first_name    String
  last_name     String
  phone         String?
  carnet        String?   @unique
  nfc_card_id   String?   @unique
  qr_code       String    @unique
  is_active     Boolean   @default(true)
  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  vehicles              Vehicle[]
  sessions              ParkingSession[]
  payments              Payment[]
  reservations          Reservation[]
  notifications         Notification[]
  audit_logs            AuditLog[]
  visitor_qrs           VisitorQR[]          @relation("GeneratedBy")
  blacklists_added      Blacklist[]          @relation("AddedBy")
  blacklists_removed    Blacklist[]          @relation("RemovedBy")
  barrier_logs          BarrierLog[]
  subscriptions         ParkingSubscription[]
  events_created        ParkingEvent[]
  monthly_bills         MonthlyBill[]
  card_replacements     CardReplacement[]    @relation("CardUser")
  card_replacements_processed CardReplacement[] @relation("CardProcessor")

  @@index([email])
  @@index([role])

  @@schema("grupo5_parqueo")
}

model Vehicle {
  id               String    @id @default(uuid())
  user_id          String
  placa            String    @unique
  brand            String?
  model            String?
  color            String?
  year             Int?
  vehicle_type     VehicleType @default(STANDARD)
  is_authorized    Boolean   @default(true)
  blacklisted      Boolean   @default(false)
  blacklist_reason String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?

  user              User             @relation(fields: [user_id], references: [id])
  sessions          ParkingSession[]
  reservations      Reservation[]
  blacklist_entries Blacklist[]

  @@index([placa])
  @@index([user_id])
  @@index([blacklisted])

  @@schema("grupo5_parqueo")
}

model ParkingSpace {
  id                String      @id @default(uuid())
  code              String      @unique
  campus_id         String
  zone              Zone
  floor             Int         @default(0)
  type              SpaceType   @default(STANDARD)
  status            SpaceStatus @default(AVAILABLE)
  is_active         Boolean     @default(true)
  lat               Float?
  lng               Float?
  last_sensor_update DateTime?
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  campus       Campus           @relation(fields: [campus_id], references: [id])
  sessions     ParkingSession[]
  reservations Reservation[]

  @@index([status])
  @@index([zone])
  @@index([campus_id])

  @@schema("grupo5_parqueo")
}

model ParkingSession {
  id               String        @id @default(uuid())
  session_code     String        @unique
  vehicle_id       String
  space_id         String
  user_id          String?
  entry_time       DateTime      @default(now())
  exit_time        DateTime?
  entry_method     EntryMethod   @default(MANUAL)
  status           SessionStatus @default(ACTIVE)
  duration_minutes Int?
  amount_due       Float?
  is_paid          Boolean       @default(false)
  operator_entry_id String?
  operator_exit_id  String?
  notes            String?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  vehicle  Vehicle      @relation(fields: [vehicle_id], references: [id])
  space    ParkingSpace @relation(fields: [space_id], references: [id])
  user     User?        @relation(fields: [user_id], references: [id])
  payment  Payment?
  visitor_qr VisitorQR?
  blockchain_audits BlockchainAudit[]

  @@index([status])
  @@index([vehicle_id])
  @@index([entry_time])
  @@index([session_code])

  @@schema("grupo5_parqueo")
}

model Payment {
  id                    String        @id @default(uuid())
  session_id            String        @unique
  user_id               String
  amount                Float
  payment_method        PaymentMethod @default(CASH)
  status                PaymentStatus @default(PENDING)
  transaction_reference String?
  paid_at               DateTime?
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  session ParkingSession @relation(fields: [session_id], references: [id])
  user    User           @relation(fields: [user_id], references: [id])

  @@schema("grupo5_parqueo")
}

model Reservation {
  id         String            @id @default(uuid())
  user_id    String
  vehicle_id String?
  space_id   String
  start_time DateTime
  end_time   DateTime
  status     ReservationStatus @default(CONFIRMED)
  type       ReservationType   @default(STANDARD)
  notes      String?
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt

  user    User         @relation(fields: [user_id], references: [id])
  space   ParkingSpace @relation(fields: [space_id], references: [id])
  vehicle Vehicle?     @relation(fields: [vehicle_id], references: [id])

  @@index([status])
  @@index([user_id])
  @@index([start_time])

  @@schema("grupo5_parqueo")
}

model Notification {
  id         String           @id @default(uuid())
  user_id    String?
  type       NotificationType
  title      String
  message    String
  is_read    Boolean          @default(false)
  read_at    DateTime?
  metadata   Json?
  created_at DateTime         @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([is_read])

  @@schema("grupo5_parqueo")
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?
  action      String
  resource    String?
  resource_id String?
  metadata    Json?
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([action])
  @@index([created_at])

  @@schema("grupo5_parqueo")
}

model Blacklist {
  id                 String    @id @default(uuid())
  vehicle_id         String
  reason             String
  added_by_user_id   String
  is_active          Boolean   @default(true)
  removed_at         DateTime?
  removed_by_user_id String?
  created_at         DateTime  @default(now())

  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id])
  added_by   User    @relation("AddedBy", fields: [added_by_user_id], references: [id])
  removed_by User?   @relation("RemovedBy", fields: [removed_by_user_id], references: [id])

  @@index([is_active])
  @@index([vehicle_id])

  @@schema("grupo5_parqueo")
}

model BarrierLog {
  id             String        @id @default(uuid())
  barrier_id     String
  action         BarrierAction
  trigger_source TriggerSource @default(MANUAL)
  operator_id    String?
  session_id     String?
  notes          String?
  created_at     DateTime      @default(now())

  operator User? @relation(fields: [operator_id], references: [id])

  @@index([barrier_id])
  @@index([created_at])

  @@schema("grupo5_parqueo")
}

model VisitorQR {
  id                   String    @id @default(uuid())
  qr_code              String    @unique
  generated_by_user_id String
  visitor_name         String
  vehicle_plate        String
  purpose              String?
  expires_at           DateTime
  is_used              Boolean   @default(false)
  used_at              DateTime?
  session_id           String?   @unique
  created_at           DateTime  @default(now())

  generated_by User           @relation("GeneratedBy", fields: [generated_by_user_id], references: [id])
  session      ParkingSession? @relation(fields: [session_id], references: [id])

  @@index([qr_code])
  @@index([expires_at])

  @@schema("grupo5_parqueo")
}

model Camera {
  id         String   @id @default(uuid())
  name       String
  location   String
  stream_url String?
  has_lpr    Boolean  @default(false)
  is_active  Boolean  @default(true)
  lat        Float?
  lng        Float?
  campus_id  String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  campus Campus? @relation(fields: [campus_id], references: [id])

  @@schema("grupo5_parqueo")
}

// ── TariffConfig — tarifas editables por rol ─────────────────────────────────

model TariffConfig {
  id                   String   @id @default(uuid())
  role                 Role     @unique
  hourly_rate          Decimal  @default(0) @db.Decimal(10, 2)
  is_free              Boolean  @default(false)
  max_free_hours       Int?
  updated_at           DateTime @updatedAt
  updated_by_user_id   String?

  @@schema("grupo5_parqueo")
}

// ── Nuevos modelos — Tarea 1 ──────────────────────────────────────────────────

enum VehicleType {
  STANDARD
  MOTORCYCLE
  HANDICAPPED
  ELECTRIC
  VIP
  TEACHER

  @@schema("grupo5_parqueo")
}

enum SubscriptionType {
  MONTHLY
  TRIMESTRAL
  SEMESTER

  @@schema("grupo5_parqueo")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING

  @@schema("grupo5_parqueo")
}

enum TariffMode {
  HOURLY
  FLAT_RATE

  @@schema("grupo5_parqueo")
}

enum EventStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED

  @@schema("grupo5_parqueo")
}

enum BillStatus {
  OPEN
  CLOSED
  PAID
  OVERDUE

  @@schema("grupo5_parqueo")
}

enum ReplacementReason {
  LOST
  DAMAGED
  STOLEN
  REASSIGNMENT

  @@schema("grupo5_parqueo")
}

model ParkingSubscription {
  id                 String             @id @default(uuid())
  user_id            String
  type               SubscriptionType
  status             SubscriptionStatus @default(ACTIVE)
  start_date         DateTime
  end_date           DateTime
  amount_paid        Decimal            @db.Decimal(10, 2)
  payment_reference  String?
  auto_renew         Boolean            @default(false)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([status])
  @@index([end_date])

  @@schema("grupo5_parqueo")
}

model ParkingEvent {
  id                    String      @id @default(uuid())
  name                  String
  description           String?
  event_date            DateTime
  start_time            DateTime
  end_time              DateTime
  tariff_mode           TariffMode  @default(HOURLY)
  flat_rate             Decimal?    @db.Decimal(10, 2)
  affected_zones        String
  status                EventStatus @default(SCHEDULED)
  created_by_user_id    String
  notes                 String?
  uses_external_parking Boolean     @default(false)
  external_parking_name String?
  shuttle_available     Boolean     @default(false)
  capacity_override     Int?
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt

  created_by User @relation(fields: [created_by_user_id], references: [id])

  @@index([event_date])
  @@index([status])

  @@schema("grupo5_parqueo")
}

model MonthlyBill {
  id                String     @id @default(uuid())
  user_id           String
  month             Int
  year              Int
  total_sessions    Int        @default(0)
  total_minutes     Int        @default(0)
  total_amount      Decimal    @default(0) @db.Decimal(10, 2)
  status            BillStatus @default(OPEN)
  due_date          DateTime
  paid_at           DateTime?
  payment_reference String?
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, month, year])
  @@index([user_id])
  @@index([month, year])
  @@index([status])

  @@schema("grupo5_parqueo")
}

model CardReplacement {
  id                  String            @id @default(uuid())
  user_id             String
  old_nfc_token       String?
  new_nfc_token       String?
  reason              ReplacementReason
  replacement_fee     Decimal           @default(50.00) @db.Decimal(10, 2)
  fee_paid            Boolean           @default(false)
  requested_at        DateTime          @default(now())
  processed_at        DateTime?
  processed_by_user_id String?
  notes               String?
  created_at          DateTime          @default(now())

  user         User  @relation("CardUser", fields: [user_id], references: [id])
  processed_by User? @relation("CardProcessor", fields: [processed_by_user_id], references: [id])

  @@schema("grupo5_parqueo")
}

model BlockchainAudit {
  id         String   @id @default(uuid())
  session_id String
  action     String
  data_hash  String
  tx_hash    String?
  network    String   @default("polygon-amoy")
  status     String   @default("CONFIRMED")
  created_at DateTime @default(now())

  session ParkingSession @relation(fields: [session_id], references: [id])

  @@index([session_id])
  @@index([created_at])
  @@index([status])

  @@schema("grupo5_parqueo")
}

// ─── Sistema Académico (Grupo 1) ─────────────────────────────────────────────

model Carrera {
  id            Int                    @id @default(autoincrement())
  codigo        String                 @unique
  nombre        String
  facultad      String?
  nivel         String                 @default("LICENCIATURA")
  activo        Boolean                @default(true)
  createdAt     DateTime               @default(now())
  alumnos       Alumno[]
  planesEstudio PlanEstudio[]
  solicitudes   SolicitudInscripcion[]

  @@schema("grupo1_academico")
}

model Alumno {
  id           Int          @id @default(autoincrement())
  carnet       String       @unique
  nombre       String
  apellido     String
  email        String       @unique
  password     String?
  carreraId    Int?
  carrera      Carrera?     @relation(fields: [carreraId], references: [id])
  createdAt    DateTime     @default(now())
  asignaciones Asignacion[]
  asistencias  Asistencia[]

  @@schema("grupo1_academico")
}

model CatedraticoAcademico {
  id        Int       @id @default(autoincrement())
  codigo    String    @unique
  nombre    String
  apellido  String
  email     String    @unique
  password  String?
  createdAt DateTime  @default(now())
  horarios  Horario[]

  @@schema("grupo1_academico")
}

model Curso {
  id           Int          @id @default(autoincrement())
  codigo       String       @unique
  nombre       String
  creditos     Int
  createdAt    DateTime     @default(now())
  asignaciones Asignacion[]
  horarios     Horario[]
  planesCurso  CursoPlan[]

  @@schema("grupo1_academico")
}

model Asignacion {
  id        Int      @id @default(autoincrement())
  alumno    Alumno   @relation(fields: [alumnoId], references: [id])
  alumnoId  Int
  curso     Curso    @relation(fields: [cursoId], references: [id])
  cursoId   Int
  ciclo     String
  createdAt DateTime @default(now())

  @@unique([alumnoId, cursoId, ciclo])
  @@schema("grupo1_academico")
}

model Horario {
  id            Int                  @id @default(autoincrement())
  curso         Curso                @relation(fields: [cursoId], references: [id])
  cursoId       Int
  catedratico   CatedraticoAcademico @relation(fields: [catedraticoId], references: [id])
  catedraticoId Int
  dia           String
  horaInicio    String
  horaFin       String
  salon         String
  asistencias   Asistencia[]

  @@schema("grupo1_academico")
}

model Asistencia {
  id        Int      @id @default(autoincrement())
  alumno    Alumno   @relation(fields: [alumnoId], references: [id])
  alumnoId  Int
  horario   Horario  @relation(fields: [horarioId], references: [id])
  horarioId Int
  fecha     DateTime
  presente  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([alumnoId, horarioId, fecha])
  @@schema("grupo1_academico")
}

model SolicitudInscripcion {
  id        Int      @id @default(autoincrement())
  nombre    String
  apellido  String
  email     String
  telefono  String
  carreraId Int
  carrera   Carrera  @relation(fields: [carreraId], references: [id])
  estado    String   @default("PENDIENTE")
  motivo    String?
  createdAt DateTime @default(now())

  @@schema("grupo1_academico")
}

model PlanEstudio {
  id            Int         @id @default(autoincrement())
  carreraId     Int
  carrera       Carrera     @relation(fields: [carreraId], references: [id])
  nombre        String
  version       String
  totalCreditos Int
  createdAt     DateTime    @default(now())
  cursos        CursoPlan[]

  @@schema("grupo1_academico")
}

model CursoPlan {
  id            Int         @id @default(autoincrement())
  planEstudioId Int
  planEstudio   PlanEstudio @relation(fields: [planEstudioId], references: [id])
  cursoId       Int
  curso         Curso       @relation(fields: [cursoId], references: [id])
  semestre      Int
  obligatorio   Boolean     @default(true)

  @@unique([planEstudioId, cursoId])
  @@schema("grupo1_academico")
}

// ─── Laboratorios (Grupo 3) ───────────────────────────────────────────────────

enum RolUsuario {
  ADMINISTRADOR
  TECNICO
  CATEDRATICO
  ESTUDIANTE

  @@schema("grupo3_laboratorios")
}

enum CategoriaUsuario {
  ESTUDIANTE_UNIVERSITARIO
  PERSONAL_COLEGIO
  PERSONAL_IGLESIA
  EVENTO_EXTERNO
  CATEDRATICO

  @@schema("grupo3_laboratorios")
}

enum TipoLaboratorio {
  COMPUTACION
  PLC_CNC
  QUIMICA
  FISICA

  @@schema("grupo3_laboratorios")
}

enum EstadoLaboratorio {
  ACTIVO
  INACTIVO
  MANTENIMIENTO

  @@schema("grupo3_laboratorios")
}

enum EstadoReserva {
  PENDIENTE
  APROBADA
  RECHAZADA
  COMPLETADA
  CANCELADA

  @@schema("grupo3_laboratorios")
}

enum TipoCobro {
  CUOTA_SEMESTRAL
  PAGO_HORA
  PAGO_DIA
  PAGO_SEMESTRE
  RESERVACION_GRUPO

  @@schema("grupo3_laboratorios")
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  ANULADO

  @@schema("grupo3_laboratorios")
}

enum EstadoEquipo {
  OPERATIVO
  MANTENIMIENTO
  DANADO
  BAJA

  @@schema("grupo3_laboratorios")
}

enum TipoConexion {
  PRESENCIAL
  REMOTA

  @@schema("grupo3_laboratorios")
}

enum TipoSancion {
  AMONESTACION
  SUSPENSION_TEMPORAL
  EXPULSION

  @@schema("grupo3_laboratorios")
}

enum EstadoMantenimiento {
  PROGRAMADO
  EN_PROCESO
  COMPLETADO

  @@schema("grupo3_laboratorios")
}

enum EstadoReporteDano {
  REPORTADO
  EN_REVISION
  COBRADO
  CERRADO

  @@schema("grupo3_laboratorios")
}

model Usuario {
  id               String           @id @default(uuid())
  correo           String           @unique
  nombre           String
  apellido         String?
  rol              RolUsuario       @default(ESTUDIANTE)
  categoria        CategoriaUsuario @default(ESTUDIANTE_UNIVERSITARIO)
  carrera          String?
  activo           Boolean          @default(true)
  reglamentoAcep   Boolean          @default(false) @map("reglamento_acep")
  sancionado       Boolean          @default(false)
  eventoExternoRef String?          @map("evento_externo_ref")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  reservas               Reserva[]              @relation("ReservaSolicitante")
  reservasAprobadas      Reserva[]              @relation("ReservaAprobador")
  sesionesUso            SesionUso[]
  pagosLab               Pago[]
  sanciones              Sancion[]
  reportesDano           ReporteDano[]             @relation("ReportePor")
  danosResponsable       ReporteDano[]             @relation("DanoResponsable")
  infracciones           Infraccion[]
  mantenimientos         MantenimientoEquipo[]     @relation("MantenimientoTecnico")

  @@map("usuario")
  @@schema("grupo3_laboratorios")
}

model Sancion {
  id            Int         @id @default(autoincrement())
  usuarioId     String      @map("usuario_id")
  tipo          TipoSancion
  motivo        String
  aplicadaPorId String?     @map("aplicada_por_id")
  fechaInicio   DateTime    @default(now()) @map("fecha_inicio")
  fechaFin      DateTime?   @map("fecha_fin")
  levantada     Boolean     @default(false)
  notas         String?
  createdAt     DateTime    @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("sancion")
  @@schema("grupo3_laboratorios")
}

model Laboratorio {
  id                 Int               @id @default(autoincrement())
  codigo             String            @unique @default("LAB-GEN")
  nombre             String
  descripcion        String?
  ubicacion          String?
  tipo               TipoLaboratorio   @default(COMPUTACION)
  capacidadTotal     Int               @default(30) @map("capacidad_total")
  permiteDivision    Boolean           @default(true) @map("permite_division")
  estado             EstadoLaboratorio @default(ACTIVO)
  faseImplementacion Int               @default(1) @map("fase_implementacion")
  disponiblePublico  Boolean           @default(true) @map("disponible_publico")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  configuraciones ConfiguracionDivision[]
  estaciones      Estacion[]
  equipos         Equipo[]
  reservas        Reserva[]
  pagos           Pago[]
  sesionesUso     SesionUso[]

  @@map("laboratorio")
  @@schema("grupo3_laboratorios")
}

model ConfiguracionDivision {
  id              Int        @id @default(autoincrement())
  laboratorioId   Int        @map("laboratorio_id")
  etiqueta        String
  cupo            Int
  esGrupoCompleto Boolean    @default(false) @map("es_grupo_completo")
  activo          Boolean    @default(true)
  orden           Int        @default(0)

  laboratorio Laboratorio  @relation(fields: [laboratorioId], references: [id], onDelete: Cascade)
  reservas    Reserva[]

  @@map("configuracion_division")
  @@schema("grupo3_laboratorios")
}

model Estacion {
  id            Int         @id @default(autoincrement())
  laboratorioId Int         @map("laboratorio_id")
  nombre        String
  tipo          String
  descripcion   String?
  orden         Int         @default(0)
  activo        Boolean     @default(true)

  laboratorio Laboratorio @relation(fields: [laboratorioId], references: [id], onDelete: Cascade)

  @@map("estacion")
  @@schema("grupo3_laboratorios")
}

model Equipo {
  id               Int          @id @default(autoincrement())
  laboratorioId    Int          @map("laboratorio_id")
  codigoInventario String       @unique @map("codigo_inventario")
  nombre           String
  esServidor       Boolean      @default(false) @map("es_servidor")
  estado           EstadoEquipo @default(OPERATIVO)
  ubicacionFisica  String?      @map("ubicacion_fisica")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  laboratorio    Laboratorio           @relation(fields: [laboratorioId], references: [id], onDelete: Cascade)
  sesionesUso    SesionUso[]
  reportesDano   ReporteDano[]
  mantenimientos MantenimientoEquipo[]

  @@map("equipo")
  @@schema("grupo3_laboratorios")
}

model MantenimientoEquipo {
  id          Int                 @id @default(autoincrement())
  equipoId    Int                 @map("equipo_id")
  tecnicoId   String?             @map("tecnico_id")
  tipo        String
  descripcion String
  costo       Decimal?            @db.Decimal(10, 2)
  estado      EstadoMantenimiento @default(PROGRAMADO)
  fecha       DateTime            @default(now())
  createdAt   DateTime            @default(now()) @map("created_at")

  equipo  Equipo   @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  tecnico Usuario? @relation("MantenimientoTecnico", fields: [tecnicoId], references: [id])

  @@map("mantenimiento_equipo")
  @@schema("grupo3_laboratorios")
}

model ReporteDano {
  id                   Int               @id @default(autoincrement())
  equipoId             Int               @map("equipo_id")
  reportadoPorId       String            @map("reportado_por_id")
  usuarioResponsableId String?           @map("usuario_responsable_id")
  descripcion          String
  requiereCobro        Boolean           @default(false) @map("requiere_cobro")
  montoCobro           Decimal?          @map("monto_cobro") @db.Decimal(10, 2)
  estado               EstadoReporteDano @default(REPORTADO)
  createdAt            DateTime          @default(now()) @map("created_at")

  equipo             Equipo   @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  reportadoPor       Usuario  @relation("ReportePor", fields: [reportadoPorId], references: [id])
  usuarioResponsable Usuario? @relation("DanoResponsable", fields: [usuarioResponsableId], references: [id])

  @@map("reporte_dano")
  @@schema("grupo3_laboratorios")
}

model Reserva {
  id                      String        @id @default(uuid())
  usuarioId               String        @map("usuario_id")
  laboratorioId           Int           @map("laboratorio_id")
  configuracionDivisionId Int?          @map("configuracion_division_id")
  fechaInicio             DateTime      @map("fecha_inicio")
  fechaFin                DateTime      @map("fecha_fin")
  cantidadPersonas        Int           @map("cantidad_personas")
  proposito               String
  estado                  EstadoReserva @default(PENDIENTE)
  aprobadaPorId           String?       @map("aprobada_por_id")
  notas                   String?
  motivoRechazo           String?       @map("motivo_rechazo")
  motivoCancelacion       String?       @map("motivo_cancelacion")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  usuario               Usuario             @relation("ReservaSolicitante", fields: [usuarioId], references: [id])
  laboratorio           Laboratorio            @relation(fields: [laboratorioId], references: [id])
  configuracionDivision ConfiguracionDivision? @relation(fields: [configuracionDivisionId], references: [id])
  aprobadaPor           Usuario?            @relation("ReservaAprobador", fields: [aprobadaPorId], references: [id])
  pagos                 Pago[]

  @@map("reserva")
  @@schema("grupo3_laboratorios")
}

model Pago {
  id                String     @id @default(uuid())
  usuarioId         String     @map("usuario_id")
  laboratorioId     Int?       @map("laboratorio_id")
  reservaId         String?    @map("reserva_id")
  monto             Decimal    @db.Decimal(10, 2)
  tipoCobro         TipoCobro  @map("tipo_cobro")
  metodoPago        String     @map("metodo_pago")
  estado            EstadoPago @default(PENDIENTE)
  referenciaExterna String?    @map("referencia_externa")
  notas             String?
  createdAt         DateTime   @default(now()) @map("created_at")

  usuario     Usuario   @relation(fields: [usuarioId], references: [id])
  laboratorio Laboratorio? @relation(fields: [laboratorioId], references: [id])
  reserva     Reserva?  @relation(fields: [reservaId], references: [id])

  @@map("pago")
  @@schema("grupo3_laboratorios")
}

model SesionUso {
  id                String       @id @default(uuid())
  usuarioId         String       @map("usuario_id")
  laboratorioId     Int?         @map("laboratorio_id")
  equipoId          Int?         @map("equipo_id")
  tipoConexion      TipoConexion @default(PRESENCIAL) @map("tipo_conexion")
  inicio            DateTime     @default(now())
  fin               DateTime?
  registroActividad Json?        @map("registro_actividad")

  usuario     Usuario   @relation(fields: [usuarioId], references: [id])
  laboratorio Laboratorio? @relation(fields: [laboratorioId], references: [id])
  equipo      Equipo?   @relation(fields: [equipoId], references: [id])
  infracciones Infraccion[]

  @@map("sesion_uso")
  @@schema("grupo3_laboratorios")
}

model Infraccion {
  id              Int        @id @default(autoincrement())
  usuarioId       String     @map("usuario_id")
  sesionUsoId     String?    @map("sesion_uso_id")
  descripcion     String
  sancionAplicada Boolean    @default(false) @map("sancion_aplicada")
  createdAt       DateTime   @default(now()) @map("created_at")

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  sesionUso SesionUso?  @relation(fields: [sesionUsoId], references: [id])

  @@map("infraccion")
  @@schema("grupo3_laboratorios")
}

// ─── Grupo 9: Otras Actividades ───────────────────────────────────────────────

enum EstadoActividad {
  Borrador
  Pendiente
  Aprobada
  Rechazada

  @@schema("grupo9_otras_actividades")
}

model Actividad {
  id                   String           @id @default(cuid())
  codigo               String           @unique
  nombre               String
  tipo                 String
  modalidad            String
  ubicacion            String           @default("")
  mapa_url             String           @default("")
  meet_url             String           @default("")
  costo                String           @default("Gratuita")
  monto                Decimal          @default(0) @db.Decimal(10, 2)
  fecha                String
  hora_inicio          String           @default("")
  hora_fin             String           @default("")
  participantes        Int              @default(0)
  asistentes_confirmados Int            @default(0)
  inscritos            String[]         @default([])
  creador              String           @default("")
  aprobador            String           @default("")
  estado               EstadoActividad  @default(Borrador)
  certificados         String           @default("No aplica")
  emite_certificado    Boolean          @default(false)
  descripcion          String           @default("")
  observacion_aprobacion String         @default("")
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt

  @@map("actividad")
  @@schema("grupo9_otras_actividades")
}
